{
  "name": "life-sync-function",
  "version": "1.0.0",
  "description": "Cloud Function for life-sync",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "functions-framework --target=app",
    "dev": "ts-node-dev --respawn src/index.ts",
    "deploy": "gcloud functions deploy life-sync-function --gen2 --runtime=nodejs22 --region=europe-west1 --trigger-http --entry-point=app --allow-unauthenticated",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":70}}'"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^3.1.0",
    "@google-cloud/storage": "^7.16.0",
    "express": "^4.18.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts", "!src/**/*.test.ts", "!src/**/*.d.ts"]
  }
}
